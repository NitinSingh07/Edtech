// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password      String?
  role          String    @default("ENGINEER") // Role: ADMIN, MANAGER, ENGINEER
  department    String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relationships
  reportedIncidents Incident[] @relation("ReportedBy")
  assignedIncidents Incident[] @relation("AssignedTo")
  comments          Comment[]
  activityLogs      ActivityLog[]

  @@map("users")
}

model Incident {
  id           String    @id @default(cuid())
  title        String
  description  String
  severity     String    @default("MEDIUM") // Severity: CRITICAL, HIGH, MEDIUM, LOW
  status       String    @default("OPEN")   // Status: OPEN, INVESTIGATING, RESOLVED, CLOSED
  priority     String    @default("P3")     // Priority: P1, P2, P3, P4
  category     String    @default("OTHER")  // Category: BUG, SECURITY, PERFORMANCE, OUTAGE, NETWORK, DATABASE, OTHER
  
  // Timestamps
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  resolvedAt   DateTime?
  closedAt     DateTime?

  // Reporting/Assignment
  reportedById String
  reportedBy   User      @relation("ReportedBy", fields: [reportedById], references: [id])
  assignedToId String?
  assignedTo   User?     @relation("AssignedTo", fields: [assignedToId], references: [id])

  // Sub-entities
  comments     Comment[]
  activityLogs ActivityLog[]
  aiSuggestions AISuggestion[]

  @@map("incidents")
  @@index([status])
  @@index([severity])
}

model Comment {
  id         String   @id @default(cuid())
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  incidentId String
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@map("comments")
}

model ActivityLog {
  id         String   @id @default(cuid())
  action     String   // e.g., "STATUS_CHANGE", "ASSIGNMENT", "COMMENT_ADDED"
  details    String?
  metadata   String?  // SQLite doesn't support Json well, using string for now
  createdAt  DateTime @default(now())

  userId     String
  user       User     @relation(fields: [userId], references: [id])
  
  incidentId String?
  incident   Incident? @relation(fields: [incidentId], references: [id], onDelete: SetNull)

  @@map("activity_logs")
}

model AISuggestion {
  id           String   @id @default(cuid())
  aiSeverity   String
  confidence   Float
  suggestions  String // SQLite doesn't support arrays, using comma-separated or JSON string
  rootCause    String?
  createdAt    DateTime @default(now())

  incidentId   String
  incident     Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@map("ai_suggestions")
}
